generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shortlist {
  id        String   @id @default(cuid())
  name      String
  carIds    String   // JSON array of car IDs, e.g. '["tata-nexon","hyundai-creta"]'
  createdAt DateTime @default(now())
}
